###############################################################################
# Catppuccin Mocha Theme for Taskwarrior - Enhanced Contrast Version
# Save this file as ~/.task/catppuccin-mocha.theme
# Then add to your .taskrc: include ~/.task/catppuccin-mocha.theme
###############################################################################

rule.precedence.color=deleted,completed,active,keyword.,tag.,project.,overdue,scheduled,due.today,due,blocked,blocking,recurring,tagged,uda.

# General decoration
color.label=
color.label.sort=
color.alternate=
color.header=white
color.footnote=white
color.warning=color11
color.error=color0 on color9
color.debug=color15

# Task state
color.completed=color8
color.deleted=color8
color.active=color15
color.recurring=color15
color.scheduled=color15
color.until=color8
color.blocking=color11
color.blocked=color9

# Project
color.project.none=

# Priority
color.uda.priority.H=color208
color.uda.priority.M=color229
color.uda.priority.L=color8

# Tags
color.tag.next=
color.tag.none=
color.tag.inbox=color12
color.tagged=

# Due
color.due=
color.due.today=color208
color.overdue=color0 on color9

# Report: burndown
color.burndown.pending=color0 on color11
color.burndown.started=color0 on color12
color.burndown.done=color0 on color10

# Report: history
color.history.add=color0 on color10
color.history.done=color0 on color10
color.history.delete=color0 on color9

# Report: summary
color.summary.bar=color0 on color12
color.summary.background=on gray2

# Command: calendar
color.calendar.due=color0 on color11
color.calendar.due.today=color0 on color11
color.calendar.holiday=color0 on color11
color.calendar.overdue=color0 on color9
color.calendar.today=color0 on color12
color.calendar.weekend=on gray2
color.calendar.weeknumber=color15

# Command: sync
color.sync.added=color10
color.sync.changed=color11
color.sync.rejected=color9

# Command: undo
color.undo.before=color11
color.undo.after=color10
