# Taskwarrior Configuration (portable — machine-specific sync goes in ~/.taskrc.work)
data.location=~/.task
news.version=3.4.2
editor=nvim

# Color theme
include ~/.task/catppuccin-mocha.theme
color.history.done=color0 on color10
color.history.add=color0 on color12

color.alternate=on color234

# Sync settings are machine-specific — create ~/.task/sync.taskrc locally
include ~/.task/sync.taskrc

# Row spacing for readability
row.padding=2

# Search
search.case.sensitive=no

# Urgency Coefficient Overrides
urgency.uda.priority.L.coefficient=-1.0

# ─── Aliases ──────────────────────────────────────────────────────────────────
alias.mod=modify
alias.proj=project
alias.prio=priority

# ─── Unified Sort Order ───────────────────────────────────────────────────────
report.active.sort=due+,urgency-
report.all.sort=due+,urgency-
report.blocked.sort=due+,urgency-
report.blocking.sort=due+,urgency-
report.list.sort=due+,urgency-
report.long.sort=due+,urgency-
report.ls.sort=due+,urgency-
report.minimal.sort=due+,urgency-
report.ready.sort=due+,urgency-
report.recurring.sort=due+,urgency-
report.unblocked.sort=due+,urgency-
report.waiting.sort=due+,urgency-
report.overdue.sort=due+,urgency-

# ─── Custom Reports ──────────────────────────────────────────────────────────

# Indies: tasks without project/tags (unless prioritized or due)
report.indies.description=Pending tasks with no project/tags unless they have priority or due
report.indies.columns=id,project,tags,priority,due,description
report.indies.labels=ID,Project,Tags,Pri,Due,Description
report.indies.filter=status:pending ( project.none: tags.none: or priority.any: or due.any: )
report.indies.sort=due+,priority-,description+

report.indiesmin.description=Indies but minimal
report.indiesmin.columns=id,description
report.indiesmin.labels=ID,Description
report.indiesmin.filter=status:pending ( project.none: tags.none: or priority.any: or due.any: )
report.indiesmin.sort=due+,priority-,description+

# ─── Machine-specific overrides (not tracked) ────────────────────────────────
# Create ~/.taskrc.work locally for sync settings, work-specific UDAs, etc.
# include ~/.taskrc.work
